---
import "../../assets/app.css";
import "../../assets/PostList.css";
import Head from "../../components/Head.astro";
import Card from "../../components/Card.astro";
import Navbar from "../../components/NavBar.astro";
import ThemeController from "../../components/ThemeController.astro";
import { Icon } from 'astro-icon/components';
import SearchModal from "../../components/SearchModal.astro";

const posts = Object.entries(import.meta.glob("../posts/*.md", { eager: true }))
    .map(([path, module]) => {
        const { frontmatter, url } = module as {
            frontmatter: {
                title?: string;
                date?: string;
                description?: string;
                topic?: string;
                tags?: string[];
            };
            url?: string;
        };

        return {
            path,
            title: frontmatter.title ?? path.split("/").pop() ?? path,
            date: frontmatter.date ?? "",
            description: frontmatter.description ?? "",
            topic: frontmatter.topic ?? "",
            tags: frontmatter.tags ?? [],
            url: url ?? path.replace("./posts", "../posts").replace(/\.md$/, "/"),
        };
    })
    .sort((a, b) => b.date.localeCompare(a.date));
---

<Head />
<Navbar />
<ThemeController />
<Card>
    <h1 class="card-title">文章总览</h1>
    <div class="w-3/5 grid grid-cols-3 gap-3">
        <a class="btn btn-outline" href="/posts/tags"><Icon name="mdi:tag-outline" />文章标签</a>
        <a class="btn btn-outline" href="/posts/topic"><Icon name="material-symbols:menu-rounded" />文章专栏</a>
        <a class="btn btn-outline" onclick="showModal()"><Icon name="material-symbols:search-rounded" />文章搜索</a>
    </div>
    <SearchModal />
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => (
            <a
                href={post.url}
                class="rounded-xl border border-base-content/10 p-4 transition list-post hover:shadow-md"
            >
                <div class="text-sm opacity-70">{post.date}</div>
                <div class="mt-2 text-lg font-semibold">{post.title}</div>
                {post.topic && <div class="mt-2 text-xs opacity-70">主题：{post.topic}</div>}
                {post.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                        {post.tags.map((tag) => (
                            <span class="rounded-full bg-base-200 px-2 py-1 text-xs">{tag}</span>
                        ))}
                    </div>
                )}
                {post.description && <p class="mt-2 line-clamp-3 text-sm opacity-75">{post.description}</p>}
            </a>
        ))}
    </div>
</Card>
